# Betreiber (für Impressum & Datenschutzerklärung)
OPERATOR_NAME=Vorname Nachname
OPERATOR_STREET=Musterstraße 1
OPERATOR_CITY=12345 Berlin
OPERATOR_COUNTRY=Deutschland
OPERATOR_EMAIL=kontakt@beispiel.de
OPERATOR_PHONE=
# Aufbewahrungsfristen (Tage) – für Datenschutzerklärung
LOG_RETENTION_DAYS=30
BACKUP_RETENTION_DAYS=30

ADZUNA_APP_ID=your_app_id_here
ADZUNA_APP_KEY=your_app_key_here
SECRET_KEY=generate-with-openssl-rand-hex-32

# Domain (muss auf diesen Server zeigen, Caddy holt HTTPS-Zertifikat automatisch)
APP_DOMAIN=your-domain.example.com

# E-Mail (Passwort-Reset)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=noreply@example.com
SMTP_PASSWORD=your-smtp-password
SMTP_FROM=JobPipeline <noreply@example.com>
APP_URL=https://your-domain.example.com
